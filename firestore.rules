rules_version = '2';
service cloud.firestore {
  // Apply security rules to all Firestore documents in the database.
  match /databases/{database}/documents {
    // Ensure the requester is authenticated before allowing access.
    function isSignedIn() {
      return request.auth != null;
    }

    // Only allow access when the authenticated user owns the target data.
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // The top-level user document. This protects /users/{userId} documents.
    // Example: /users/abc123 can only be read or written by user auth UID abc123.
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // Protect nested collections under the user document as well.
    // Example: /users/abc123/accounts/accountA and /users/abc123/transactions/tx1
    match /users/{userId}/{document=**} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }
  }
}
